# ===========================================
# zotero-arxiv-daily — Web Server (.env)
# ===========================================
# Copy this file to .env and fill in your values.
# .env is already in .gitignore so your secrets stay local.

# --- LLM ---
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
MODEL_NAME=gpt-4o
LANGUAGE=Chinese

# --- arXiv ---
ARXIV_QUERY=cat:cs.AI+cat:cs.CV+cat:cs.LG+cat:cs.CL+cat:cs.RO
MAX_PAPER_NUM=25

# --- Email (SMTP) ---
SMTP_SERVER=smtp.qq.com
SMTP_PORT=465
SENDER=your-email@qq.com
SENDER_PASSWORD=your-smtp-auth-code
RECEIVER=receiver@example.com

# --- Server LLM Access Control (optional) ---
# If set, users must enter this password in the web UI to use the server-side LLM.
# Leave empty to allow access without password.
SERVER_LLM_PASSWORD=
